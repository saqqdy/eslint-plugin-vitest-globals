{
	"name": "eslint-plugin-vitest-globals",
	"description": "ESLint plugin for Vitest globals",
	"version": "1.5.0",
	"packageManager": "pnpm@8.6.7",
	"main": "./index.js",
	"types": "./index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"require": "./index.js",
			"default": "./index.js"
		}
	},
	"files": [
		"configs",
		"index.js",
		"index.d.ts"
	],
	"scripts": {
		"pub": "tscjs scripts/publish",
		"unpub": "tscjs scripts/unpublish",
		"sync": "tscjs scripts/sync",
		"dist": "pnpm run prettier",
		"eslint": "eslint --fix .",
		"prettier": "prettier --write \"**/*.{js,ts,sh,json,md}\"",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@eslint-sets/eslint-config-ts": "^5.12.0",
		"@types/node": "^20.11.27",
		"eslint": "^8.57.0",
		"prettier": "^3.2.5",
		"prettier-config-common": "^1.4.0",
		"reinstaller": "^3.0.2",
		"tsnd": "^1.1.0",
		"typescript": "^5.4.2",
		"vitest": "^1.6.1"
	},
	"engines": {
		"node": ">=16"
	},
	"pnpm": {
		"peerDependencyRules": {
			"ignoreMissing": [
				"tslib",
				"webpack"
			],
			"allowedVersions": {
				"eslint": "^8.0.0"
			}
		},
		"overrides": {
			"@babel/traverse": ">=7.23.2",
			"yaml": ">=2.2.2",
			"braces": ">=3.0.3",
			"minimatch": ">=9.0.7",
			"esbuild": ">=0.25.0",
			"ajv": ">=6.14.0"
		}
	},
	"keywords": [
		"vitest",
		"vitest env",
		"vitest globals",
		"vitest eslint",
		"eslint-plugin-vitest-globals",
		"eslint-plugin",
		"eslint",
		"eslint-extends",
		"saqqdy"
	],
	"license": "MIT",
	"author": "saqqdy <https://github.com/saqqdy>",
	"homepage": "https://github.com/saqqdy/eslint-plugin-vitest-globals#readme",
	"bugs": {
		"url": "https://github.com/saqqdy/eslint-plugin-vitest-globals/issues"
	},
	"repository": {
		"type": "git",
		"url": "http://github.com/saqqdy/eslint-plugin-vitest-globals.git"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	}
}
