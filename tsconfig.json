{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist",
		"rootDir": ".",
		"types": ["node"]
	},
	"include": ["scripts/**/*.ts", "index.d.ts"],
	"exclude": ["node_modules", "dist", "test"]
}
